{
  "name": "solar-system",
  "version": "1.0.0",
  "description": "Interactive solar system visualization built with vanilla JavaScript and CSS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\""
  },
  "keywords": [
    "solar-system",
    "visualization",
    "javascript",
    "css",
    "astronomy"
  ],
  "author": "",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.1.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2",
    "vite": "^6.0.0"
  }
}
